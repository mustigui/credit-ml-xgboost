# Copy to .env and adjust. docker-compose can load this via `env_file: .env` if you add it.

# MLflow (use http://mlflow:5000 inside Docker Compose network; http://localhost:5000 from host)
MLFLOW_TRACKING_URI=http://localhost:5000

# Optional: CSV from Kaggle (must include target column from config/default.yaml)
# KAGGLE_DATA_PATH=C:/path/to/dataset.csv

# Run drift check on the same schedule as monthly inference (scheduler only)
SCHEDULE_DRIFT_WITH_INFERENCE=1
